# Required: Your Unravel API key
UNRAVEL_API_KEY=your_api_key_here

# Optional: Override base URL to test against staging
# UNRAVEL_BASE_URL=https://staging.unravel.finance

# Optional: Cloudflare Access service token for staging (required when UNRAVEL_BASE_URL points to a protected environment)
# CF_ACCESS_CLIENT_ID=your_client_id_here
# CF_ACCESS_CLIENT_SECRET=your_client_secret_here
